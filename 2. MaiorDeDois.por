programa {
  funcao inicio() {
    inteiro val1
    inteiro val2

    escreva("escreva doi números: ")
    leia(val1)
    leia(val2)

    se(val1 > val2)
      escreva("\n" + val1 + " é maior que " + val2)

      senao se(val1 < val2)
      escreva("\n" + val1 + " é menor que " + val2)

      senao se(val1 == val2)
      escreva("\n" + val1 + " é igual a " + val2)
    

    
    


    
  }
}
