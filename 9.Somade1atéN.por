programa {
  funcao inicio() {
    inteiro n, soma, valfi, contador = 0, valll = 0

    escreva("escreva um número: ")
    leia(n)


    faca{
    soma = valll
   valll = valll + 1
    valfi = soma + valll
    

    contador = contador + 1
    
    }enquanto(contador != n)
    
    escreva("soma total = ", valfi)

    
  }
}
